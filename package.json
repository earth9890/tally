{
  "name": "tally",
  "productName": "Tally",
  "version": "0.1.1",
  "description": "Tally — local-first, automatic personal time tracker for macOS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist": "electron-builder --mac --publish never",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "io.earth9890.tally",
    "productName": "Tally",
    "asarUnpack": [
      "node_modules/get-windows/**",
      "**/*.node"
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": [
      { "provider": "github", "owner": "earth9890", "repo": "tally" }
    ]
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.9",
    "get-windows": "^9.2.0"
  }
}
